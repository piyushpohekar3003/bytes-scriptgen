# Optional: Set your own Anthropic API key (overrides the default)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# HeyGen API key (required for avatar video generation)
# HEYGEN_API_KEY=

# Optional: Restrict the voice picker to specific voice IDs (comma-separated).
# HeyGen's /v2/voices returns 2000+ stock + cloned voices mixed together with
# no way to filter server-side. Set this to show only your cloned voices.
# Avatar default voices are always included automatically.
# HEYGEN_VOICE_IDS=abc123,def456
